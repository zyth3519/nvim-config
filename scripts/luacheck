#!/bin/sh

set -eu

LUA_BIN="${LUA_BIN:-lua5.4}"
LUACHECK_MAIN="/usr/lib/luarocks/rocks-5.5/luacheck/1.2.0-1/bin/luacheck"
LUACHECK_PATH="/usr/share/lua/5.5/?.lua;/usr/share/lua/5.5/?/init.lua;"

if ! command -v "$LUA_BIN" >/dev/null 2>&1; then
	echo "scripts/luacheck: missing Lua interpreter: $LUA_BIN" >&2
	exit 1
fi

exec "$LUA_BIN" \
	-e "package.path='${LUACHECK_PATH}'..package.path" \
	"$LUACHECK_MAIN" \
	"$@"
